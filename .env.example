DISCORD_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=
CODYSSEY_DB_PATH=codyssey_coach.sqlite3

# --- 아래는 클라우드 배포 시에만 필요 (로컬 실행이면 비워두세요) ---

# Turso (https://turso.tech) 무료 DB. 설정하면 재배포해도 데이터가 유지됩니다.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# 헬스체크 서버 포트 (Render 등이 PORT를 자동 주입하므로 보통 비워둬도 됨)
PORT=8080

# 무료 인스턴스 잠들기 방지: 배포 후 받은 공개 URL (예: https://xxx.onrender.com/health)
KEEP_ALIVE_URL=
